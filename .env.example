# ─── Copy to .env.local and fill in your values ──────────────────────
# These are PUBLIC — safe to put here (Firebase web config is designed to be public)
# Your SECRET keys (Claude, TMDB) are on the BACKEND, not here.

# Your Railway backend URL (update after deploying backend)
VITE_API_URL=https://your-backend.railway.app

# Firebase Web Config (get from Firebase Console → Project Settings → Your Apps)
VITE_FIREBASE_API_KEY=AIzaSy-your-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456
